# Copy to .env and fill in values from Supabase: Project Settings -> API
#   cp .env.example .env
#
# Do not commit .env (it is gitignored).

# Project URL, e.g. https://abcdefghijklmnop.supabase.co
SUPABASE_URL=

# Anon/public key — sufficient for reading tools (RLS read)
SUPABASE_KEY=

# Service role key — required for scripts/ingest_tool_libraries.py
# Never expose in frontend code or commit to git
SUPABASE_SERVICE_ROLE_KEY=
